# Per-machine working dirs: venv, audio copies, transcripts, state, logs.
# Raw call audio + transcripts are kept LOCAL (privacy) — not committed.
**/.work/

# Python
__pycache__/
*.pyc

# Secrets / env
.env
*.key
*.pem

# macOS
.DS_Store

# inbox/ — local drop zone for context-update. Raw drops stay local (privacy,
# same policy as transcripts); only the distilled wiki (context/) is committed.
inbox/*
!inbox/README.md
