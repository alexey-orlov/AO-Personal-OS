    {
      "id": "apply",
      "name": "Apply reaction",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        400
      ],
      "parameters": {
        "jsCode": "// 👍 added → done; 👍 removed → reopen. Input from 'When called (toggle)':\n// { messageId, makeDone }. renderItem() MUST stay in sync with 'Plan posts and edits'.\nconst today = DateTime.now().setZone('Europe/Kyiv').toFormat('yyyy-LL-dd');\nconst g = $input.first().json;\nlet md = Buffer.from(g.content, 'base64').toString('utf8');\nconst t = $('When called (toggle)').first().json;\nconst msgId = String(t.messageId || '');\nconst makeDone = !!t.makeDone;\nif (!msgId) return [];\nconst re = new RegExp('^- \\\\[([ x])\\\\] \\\\*\\\\*([gt]\\\\d+)\\\\*\\\\* — .*· tg:' + msgId + '\\\\b.*$', 'm');\nconst m = md.match(re);\nif (!m) return []; // reaction on a non-item message — ignore\nconst line = m[0];\nif ((m[1] === 'x') === makeDone) return []; // already in that state\nlet newLine;\nif (makeDone) {\n  newLine = line.replace('- [ ]', '- [x]');\n  if (!/ · done \\d{4}-\\d{2}-\\d{2}/.test(newLine)) newLine += ' · done ' + today;\n} else {\n  newLine = line.replace('- [x]', '- [ ]').replace(/ · done \\d{4}-\\d{2}-\\d{2}/, '');\n}\nmd = md.replace(line, newLine);\nconst id = m[2];\nfunction renderItem(it) {\n  const type = it.id.startsWith('g') ? '🎯' : '☑️';\n  if (it.done) return `✅ ${type} ${it.id} — ${it.text}` + (it.doneDate ? ` · done ${it.doneDate}` : '');\n  return `${type} ${it.id} — ${it.text}`;\n}\nconst text = newLine.match(/\\*\\* — (.*)$/)[1].split(' · ')[0].trim();\nconst dd = newLine.match(/· done (\\d{4}-\\d{2}-\\d{2})/);\nreturn [{ json: {\n  contentB64: Buffer.from(md, 'utf8').toString('base64'), sha: g.sha,\n  commitMsg: 'goals-tasks: ' + (makeDone ? 'done ' : 'reopen ') + id + ' (👍)',\n  msgId, text: renderItem({ id, done: makeDone, text, doneDate: dd ? dd[1] : '' })\n} }];"
      }
    },
