    {
      "id": "writeback",
      "name": "Stamp tg ids",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        60
      ],
      "parameters": {
        "jsCode": "// Append · tg:<message_id> to each just-posted line → one PUT.\nconst g = $('GET file (cron)').first().json;\nlet md = Buffer.from(g.content, 'base64').toString('utf8');\nconst planned = $('Plan posts and edits').all().filter(i => i.json.mode === 'post');\nconst sent = $input.all();\nfor (let i = 0; i < sent.length; i++) {\n  const id = planned[i].json.id;\n  const mid = sent[i].json.result.message_id;\n  const re = new RegExp('^(- \\\\[[ x]\\\\] \\\\*\\\\*' + id + '\\\\*\\\\* — .*)$', 'm');\n  md = md.replace(re, (l) => l + ' · tg:' + mid);\n}\nif (!sent.length) return [];\nreturn [{ json: { contentB64: Buffer.from(md, 'utf8').toString('base64'), sha: g.sha,\n                  commitMsg: 'goals-tasks: stamp tg ids for ' + sent.length + ' posted item(s)' } }];"
      }
    },
