      "name": "Decode card",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        -200
      ],
      "parameters": {
        "jsCode": "// Card JSON (written by automations/telegram/config.sh tg_queue_outbox) → Telegram payload.\nreturn $input.all().map(it => {\n  const j = it.json;\n  const card = JSON.parse(Buffer.from(j.content, 'base64').toString('utf8'));\n  const payload = { chat_id: 'REDACTED_GROUP_CHAT_ID', text: card.text, disable_web_page_preview: true };\n  if (card.thread_id) payload.message_thread_id = Number(card.thread_id);\n  if (card.parse_mode) payload.parse_mode = card.parse_mode;\n  if (card.buttons && card.buttons.length) payload.reply_markup = { inline_keyboard: card.buttons };\n  return { json: { tgPayload: JSON.stringify(payload), path: j.path, sha: j.sha, name: j.name } };\n});"
      }
    },
