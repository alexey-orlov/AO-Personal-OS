    {
      "id": "plan",
      "name": "Plan posts and edits",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        150
      ],
      "parameters": {
        "jsCode": "// goals-tasks.md → one item per goal/task: mode 'post' (no tg: id yet) or 'edit'\n// (re-render posted message to current state; 'not modified' edits are no-ops).\n// renderItem() MUST stay in sync with the copy in 'Apply reaction'.\nconst g = $input.first().json;\nconst md = Buffer.from(g.content, 'base64').toString('utf8');\nfunction parseItems(text) {\n  let section = '';\n  const out = [];\n  for (const ln of text.split('\\n')) {\n    if (/^## Goals/.test(ln)) { section = 'g'; continue; }\n    if (/^## Tasks/.test(ln)) { section = 't'; continue; }\n    if (/^## /.test(ln)) { section = ''; continue; }\n    const m = ln.match(/^- \\[([ x])\\] \\*\\*([gt]\\d+)\\*\\* — (.*)$/);\n    if (!m || !section) continue;\n    const tg = ln.match(/· tg:(\\d+)\\b/);\n    const dd = ln.match(/· done (\\d{4}-\\d{2}-\\d{2})/);\n    out.push({ done: m[1] === 'x', id: m[2], text: m[3].split(' · ')[0].trim(),\n               msgId: tg ? tg[1] : '', doneDate: dd ? dd[1] : '' });\n  }\n  return out;\n}\nfunction renderItem(it) {\n  const type = it.id.startsWith('g') ? '🎯' : '☑️';\n  if (it.done) return `✅ ${type} ${it.id} — ${it.text}` + (it.doneDate ? ` · done ${it.doneDate}` : '');\n  return `${type} ${it.id} — ${it.text}`;\n}\nreturn parseItems(md).map(it => ({ json: it.msgId\n  ? { mode: 'edit', msgId: it.msgId, text: renderItem(it) }\n  : { mode: 'post', id: it.id, text: renderItem(it) } }));"
      }
    },
