    {
      "id": "cards",
      "name": "Outbox cards to items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        -200
      ],
      "parameters": {
        "jsCode": "// Directory listing → one item per queued .json card. Tolerates 404 / error shapes.\nconst out = [];\nfor (const it of $input.all()) {\n  const j = it.json;\n  const entries = Array.isArray(j) ? j : (j && j.name ? [j] : []);\n  for (const e of entries) {\n    if (!e || !e.name || !e.name.endsWith('.json')) continue;\n    out.push({ json: { name: e.name, path: e.path, sha: e.sha, url: e.url } });\n  }\n}\nreturn out;"
      }
    },
