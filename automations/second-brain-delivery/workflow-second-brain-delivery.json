    {
      "id": "prep",
      "name": "Toggle + render boards",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        150
      ],
      "parameters": {
        "jsCode": "// ONE renderer for the 🎯 Goals & Tasks pinned boards.\n// Source of truth: context/knowledge/goals-tasks.md (fetched by 'GET goals file').\n// Modes: render (schedule) | toggle (called from 'Drop Zone capture' on a gt:<id> button tap).\nconst today = DateTime.now().setZone('Europe/Kyiv').toFormat('yyyy-LL-dd');\nconst resp = $input.first().json;\nlet md = Buffer.from(resp.content, 'base64').toString('utf8');\nconst sha = resp.sha;\n\nlet itemId = '';\ntry {\n  const t = $('When called (toggle)').first().json;\n  if (t && t.itemId) itemId = String(t.itemId);\n} catch (e) { /* schedule mode */ }\n\nlet needPut = false, commitMsg = '';\nif (itemId && /^[gt]\\d+$/.test(itemId)) {\n  const re = new RegExp('^(- \\\\[)([ x])(\\\\] \\\\*\\\\*' + itemId + '\\\\*\\\\* — .*)$', 'm');\n  const m = md.match(re);\n  if (m) {\n    let line;\n    if (m[2] === ' ') {\n      line = m[1] + 'x' + m[3];\n      if (!/ · done \\d{4}-\\d{2}-\\d{2}/.test(line)) line += ' · done ' + today;\n      commitMsg = 'goals-tasks: done ' + itemId + ' (board tap)';\n    } else {\n      line = (m[1] + ' ' + m[3]).replace(/ · done \\d{4}-\\d{2}-\\d{2}/, '');\n      commitMsg = 'goals-tasks: reopen ' + itemId + ' (board tap)';\n    }\n    md = md.replace(re, () => line);\n    needPut = true;\n  }\n}\n\nfunction parseBoards(text) {\n  let section = '';\n  const goals = [], tasks = [];\n  for (const ln of text.split('\\n')) {\n    if (/^## Goals/.test(ln)) { section = 'g'; continue; }\n    if (/^## Tasks/.test(ln)) { section = 't'; continue; }\n    if (/^## /.test(ln)) { section = ''; continue; }\n    const m2 = ln.match(/^- \\[([ x])\\] \\*\\*([gt]\\d+)\\*\\* — (.*)$/);\n    if (!m2 || !section) continue;\n    const item = { done: m2[1] === 'x', id: m2[2], text: m2[3].split(' · ')[0].trim() };\n    (section === 'g' ? goals : tasks).push(item);\n  }\n  return { goals, tasks };\n}\nfunction renderBoard(title, items) {\n  const body = items.length\n    ? items.map(i => (i.done ? '✅' : '⬜') + ' ' + i.id + ' — ' + i.text).join('\\n')\n    : '(empty)';\n  const text = title + ' — ' + today + '\\n\\n' + body + '\\n\\n✓ marks done · ↩ reopens';\n  const btns = items.map(i => ({ text: (i.done ? '↩ ' : '✓ ') + i.id, callback_data: 'gt:' + i.id }));\n  const kb = [];\n  for (let i = 0; i < btns.length; i += 3) kb.push(btns.slice(i, i + 3));\n  return { text, kb };\n}\nconst { goals, tasks } = parseBoards(md);\nconst g = renderBoard('🎯 Goals', goals);\nconst t = renderBoard('☑️ Tasks', tasks);\nconst gm = md.match(/^tg_goals_message_id:\\s*\"?(\\d+)\"?/m);\nconst tm = md.match(/^tg_tasks_message_id:\\s*\"?(\\d+)\"?/m);\n\nreturn [{ json: {\n  needPut, commitMsg, sha,\n  contentB64: Buffer.from(md, 'utf8').toString('base64'),\n  hasIds: !!(gm && tm),\n  goalsMsgId: gm ? gm[1] : '', tasksMsgId: tm ? tm[1] : '',\n  goalsText: g.text, goalsKb: g.kb,\n  tasksText: t.text, tasksKb: t.kb\n} }];"
      }
    },
