# topics.env — TG_TOPIC slug → message_thread_id map for the forum group.
# Generated by setup_group.sh (AO Personal OS). Committed: thread ids aren't secrets.
# The group chat id itself lives in Keychain (TELEGRAM_GROUP_CHAT_ID).
TG_TOPIC_ENGLISH_COACHING=3
TG_TOPIC_INBOX_DRAFTS=4
TG_TOPIC_DAILY_DIGEST=5
TG_TOPIC_BOOKS=6
TG_TOPIC_DROPZONE=7
TG_TOPIC_INSIGHTS=50
TG_TOPIC_EXPLORE=51
